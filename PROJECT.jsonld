{
  "@context": "https://gftd.ai/ns/project",
  "@type": "Project",
  "@id": "did:web:watashi.gftd.ai",
  "name": "watashi",
  "displayName": "Watashi (渡し)",
  "description": "Cross-platform mouse/keyboard sharing between macOS and Windows machines. Cursor ferry between screens. Rust native agent + WASM coordination + KAMI Engine UI.",
  "domain": "watashi.gftd.ai",
  "status": "developing",
  "runtimeType": "native",
  "capabilities": [
    "input-capture",
    "input-injection",
    "screen-sharing",
    "clipboard-sync",
    "encrypted-transport"
  ],
  "platforms": ["macos", "windows"],
  "dependencies": [
    "kami-bridge",
    "kami-knp",
    "kami-input",
    "kami-ui-gpu",
    "magatama-kami-host"
  ]
}
